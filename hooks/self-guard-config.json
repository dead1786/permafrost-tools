{
  "$schema": "self-guard-config-schema.json",
  "_comment": "Configuration for self-guard.py PreResponse hook. Add/remove patterns to customize detection. Patterns are Python regex strings. Set a mode to null or empty array to disable it.",

  "enabled": true,

  "mode_f": {
    "_comment": "Mode F: Ask instead of do. AI asks 'want me to...?' instead of just doing it.",
    "enabled": true,
    "patterns": [
      "want me to",
      "shall I",
      "should I",
      "would you like me to",
      "do you want me to",
      "if you( would)? like",
      "I can .{0,20} if you",
      "let me know if",
      "would you prefer",
      "I could .{0,20} for you",
      "want me to go ahead",
      "do you need me to"
    ],
    "patterns_zh": [
      "\u8981\u6211[^\u3002\uff0c\\n]{0,4}\u55ce",
      "\u8981\u4e0d\u8981\u6211",
      "\u9700\u8981\u6211[^\u3002\uff0c\\n]{0,4}\u55ce",
      "\u9700\u8981\u55ce",
      "\u8981\u55ce",
      "\u8981\u4e0d\u8981[^\u3002\uff0c\\n]{0,6}[\uff1f?]",
      "\u9700\u4e0d\u9700\u8981",
      "\u8981\u6211\u5e6b",
      "\u8981\u6211\u53bb",
      "\u5982\u679c\u4f60\u9700\u8981",
      "\u6211\u53ef\u4ee5.{0,10}\u5982\u679c"
    ],
    "warning": "Mode F (Ask instead of do): Your response asks the user for permission instead of acting. When you detect a problem or receive a clear instruction, act on it directly and report the result. Replace 'want me to...?' with 'done, here's what I did'."
  },

  "mode_g": {
    "_comment": "Mode G: Acknowledge without action. User gives a change request, AI says 'got it' but uses no tools.",
    "enabled": true,
    "change_indicators": [
      "change .{0,10} to",
      "set .{0,10} to",
      "update .{0,10} to",
      "modify",
      "replace .{0,10} with",
      "rename .{0,10} to",
      "switch .{0,10} to",
      "move .{0,10} to",
      "add .{0,10} to",
      "remove .{0,10} from",
      "delete",
      "fix",
      "make it",
      "refactor",
      "increase .{0,10} to",
      "decrease .{0,10} to",
      "\\d+\\s*%",
      "threshold",
      "parameter",
      "config"
    ],
    "change_indicators_zh": [
      "\u6539[\u70ba\u6210\u5230]",
      "\u8a2d[\u70ba\u6210\u5b9a]",
      "\u8abf[\u5230\u70ba\u6210\u6574]",
      "\u63db[\u6210\u70ba\u5230]",
      "\u6539\\s*\\d",
      "\\d+\\s*%",
      "\u95be\u503c",
      "\u8a2d\u5b9a.*\\d",
      "\u53c3\u6578.*\\d",
      "\u522a\u6389",
      "\u79fb\u9664",
      "\u65b0\u589e",
      "\u4fee\u6539"
    ],
    "ack_patterns": [
      "got it",
      "understood",
      "sure",
      "will do",
      "noted",
      "I('ll| will)",
      "absolutely",
      "of course",
      "no problem",
      "right away",
      "I understand",
      "makes sense",
      "^OK",
      "^ok",
      "^Sure"
    ],
    "ack_patterns_zh": [
      "\u6536\u5230",
      "\u597d\u7684",
      "\u4e86\u89e3",
      "OK",
      "\u6c92\u554f\u984c",
      "\u5df2[\u8abf\u6539\u8a2d\u66f4]",
      "\u660e\u767d",
      "\u77e5\u9053\u4e86"
    ],
    "warning": "Mode G (Acknowledge without action): The user gave a change/update instruction but your response only contains text acknowledgment with no tool usage. Act first (use tools to make the change), then describe what you did."
  },

  "mode_e": {
    "_comment": "Mode E: Sycophancy. User challenges, AI immediately surrenders without analysis.",
    "enabled": true,
    "surrender_threshold": 2,
    "max_response_length": 200,
    "challenge_patterns": [
      "that's wrong",
      "that is wrong",
      "no,? that",
      "are you sure",
      "I don't think",
      "that's not right",
      "that's incorrect",
      "you're wrong",
      "actually,? no",
      "wait,? no",
      "this is wrong",
      "incorrect",
      "you made a mistake",
      "that doesn't look right",
      "try again"
    ],
    "challenge_patterns_zh": [
      "\u4e0d[\u662f\u5c0d]",
      "\u932f\u4e86",
      "\u4e0d\u5c0d\u5427",
      "\u70ba\u4ec0\u9ebc",
      "\u4f60\u78ba\u5b9a",
      "\u641e\u932f",
      "\u4e0d\u662f\u9019\u6a23",
      "\u4f60\u6c92\u6709",
      "\u4f60[\u53c8\u518d]",
      "\u600e\u9ebc[\u53c8\u6703]"
    ],
    "surrender_patterns": [
      "you're right",
      "you are right",
      "my mistake",
      "my apologies",
      "I was wrong",
      "I apologize",
      "I'm sorry",
      "sorry about that",
      "I stand corrected",
      "good catch",
      "you're correct",
      "my bad",
      "I should have",
      "fair point",
      "I agree"
    ],
    "surrender_patterns_zh": [
      "\u4f60\u8aaa\u5f97\u5c0d",
      "\u78ba\u5be6[\u662f\u5982]",
      "^\u78ba\u5be6",
      "\u6211[\u7684]?\u932f",
      "\u62b1\u6b49",
      "\u5c0d\u4e0d\u8d77",
      "\u4f60\u662f\u5c0d\u7684",
      "\u6c92\u932f"
    ],
    "warning": "Mode E (Sycophancy): The user challenged your response and you immediately agreed without analysis. If you were actually wrong, explain *what* was wrong and provide a corrected answer. If you were right, defend your position with evidence. Never capitulate without reasoning."
  },

  "passive_wait": {
    "_comment": "Passive waiting: AI defers action with 'tomorrow', 'later', etc. without concrete justification.",
    "enabled": true,
    "patterns": [
      "tomorrow",
      "later",
      "next time",
      "another time",
      "in the future",
      "eventually",
      "when .{0,10} ready",
      "once .{0,10} available",
      "for now.{0,10}skip",
      "we('ll| will) .{0,10} later",
      "let's .{0,10} later",
      "can .{0,10} later",
      "put .{0,10} on hold",
      "defer",
      "postpone"
    ],
    "patterns_zh": [
      "\u7b49[\u4e00\u4e0b\u4ed6\u5979\u5b83\u5011\u76e4]",
      "\u660e\u5929\u518d",
      "\u4e0b\u6b21\u518d",
      "\u4e4b\u5f8c\u518d",
      "\u7b49\u76e4\u5f8c",
      "\u6539\u5929",
      "\u7b49[\u6709\u7a7a\u9592]",
      "\u5148\u4e0d[\u52d5\u505a\u7ba1]"
    ],
    "action_overrides": [
      "now",
      "immediately",
      "right away",
      "right now",
      "already",
      "just did",
      "done",
      "completed",
      "finished",
      "in progress"
    ],
    "action_overrides_zh": [
      "\u73fe\u5728",
      "\u7acb\u523b",
      "\u99ac\u4e0a",
      "\u6211[\u5148\u53bb]",
      "\u76f4\u63a5",
      "\u5df2\u7d93"
    ],
    "warning": "Passive waiting: Your response defers action with words like 'later', 'tomorrow', 'next time' without a concrete reason. If you can do it now, do it. If you genuinely cannot, explain specifically why and set up tracking for when it should happen."
  }
}
